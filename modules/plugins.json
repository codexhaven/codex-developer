{
  "plugins": {
    "sed-patcher": {
      "script": "sed-patcher.sh",
      "when": "on-patch-fail",
      "description": "Targeted edits for large files"
    },
    "template-detect": {
      "script": "template-detect.sh",
      "when": "on-queue-empty",
      "description": "Project type detection"
    },
    "pattern-match": {
      "script": "pattern-match.sh",
      "when": "after-build",
      "description": "Save reusable code patterns"
    },
    "failure-check": {
      "script": "failure-check.sh",
      "when": "after-verify",
      "description": "Scan for known bad patterns"
    },
    "self-test": {
      "script": "self-test.sh",
      "when": "after-all-done",
      "description": "Run pytest on project"
    },
    "symbol-check": {
      "script": "symbol-check.sh",
      "when": "after-all-done",
      "description": "Cross-file reference verification"
    },
    "stripe-init": {
      "script": "stripe-init.sh",
      "when": "before-build",
      "description": "Stripe checkout + webhooks"
    },
    "resend-init": {
      "script": "resend-init.sh",
      "when": "before-build",
      "description": "Resend welcome emails"
    },
    "posthog-init": {
      "script": "posthog-init.sh",
      "when": "after-build",
      "description": "PostHog analytics tracking"
    },
    "sentry-init": {
      "script": "sentry-init.sh",
      "when": "after-build",
      "description": "Sentry error tracking"
    },
    "vercel-deploy": {
      "script": "vercel-deploy.sh",
      "when": "after-all-done",
      "description": "Vercel deployment config"
    },
    "supabase-init": {
      "script": "supabase-init.sh",
      "when": "before-build",
      "description": "Supabase schema + RLS policies"
    },
    "vibestack": {
      "script": "vibestack/apply.sh",
      "when": "before-build",
      "description": "Apply VibeStack standards to web projects"
    },
    "github-push": {
      "script": "github-push.sh",
      "when": "after-all-done",
      "description": "Push project to GitHub"
    }
  },
  "hooks": {
    "on-patch-fail": [],
    "on-queue-empty": [],
    "after-build": [
      "posthog-init",
      "sentry-init"
    ],
    "after-verify": [],
    "after-all-done": [
      "vercel-deploy",
      "github-push"
    ],
    "before-build": [
      "stripe-init",
      "resend-init",
      "supabase-init",
      "vibestack"
    ],
    "on-clone": [],
    "on-review-complete": []
  }
}