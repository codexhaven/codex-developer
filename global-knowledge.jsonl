{"type": "pattern", "name": "fetch-with-error-handling", "code": "async function fetchData(url){try{const r=await fetch(url);if(!r.ok)throw new Error('HTTP '+r.status);return await r.json()}catch(e){console.error(e);return null}}", "tags": ["javascript", "fetch", "error-handling"]}
{"type": "pattern", "name": "single-file-html-template", "code": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>App</title><style>/* styles */</style></head><body><!-- content --><script>/* code */</script></body></html>", "tags": ["html", "template", "single-file"]}
{"type": "rule", "rule": "NEVER rewrite a working file from scratch. Always READ the current file first. Make surgical changes. If a feature already exists, skip it.", "tags": ["critical", "always-apply"]}
{"type": "rule", "rule": "Before generating tasks, list all existing files and their key functions. Generate tasks only for MISSING features.", "tags": ["task-generation", "critical"]}
{"type": "rule", "rule": "Maximum 40 lines changed per cycle. Use git diff to verify.", "tags": ["limits", "critical"]}
{"type": "rule", "rule": "Always verify syntax before commit. On failure, revert and log.", "tags": ["verification", "critical"]}
